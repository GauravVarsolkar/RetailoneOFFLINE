<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.Activity.DashboardActivity.ExpenseRegisterActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            android:minHeight="?attr/actionBarSize"
            android:theme="?attr/actionBarTheme">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="1"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="5dp"
                    android:backgroundTint="#fff"
                    android:adjustViewBounds="true"
                    android:src="@drawable/mlogo"
                    android:layout_gravity="center"
                    android:layout_weight="0.5"
                    android:padding="4dp"
                    android:layout_marginEnd="56dp"
                    android:id="@+id/image"/>

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:isScrollContainer="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="8dp">


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/pettycash_layout"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1"
                app:cardCornerRadius="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradiant_card_bg"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:id="@+id/pettycash_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/icon_wallet_svg"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/light_white" />

                    <TextView
                        android:id="@+id/pcash"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/avenirnextltpro_medium"
                        android:gravity="center"
                        android:text="Petty Cash Account"
                        android:textSize="16dp"
                        android:textColor="@color/light_white"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/balance_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/avenirnextltpro_medium"
                        android:gravity="center_horizontal"

                        android:text="Balance"
                        android:textColor="@color/light_white"
                        android:textSize="14dp"
                        app:layout_constraintBottom_toTopOf="@+id/balance"
                        app:layout_constraintStart_toStartOf="parent" />


                    <TextView
                        android:id="@+id/balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/avenirnextltpro_medium"
                        android:gravity="center_horizontal"
                        android:text="000.00"
                        android:textColor="@color/white"

                        android:textSize="20dp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/pettycash_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradiant_card_bg"
                        android:backgroundTint="@color/white"
                        android:fontFamily="@font/avenirnextltpro_medium"
                        android:drawableEnd="@drawable/icon_forward_svg"
                        android:drawablePadding="1dp"
                        android:gravity="center_horizontal"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="4dp"
                        android:text="View Details"

                        android:textColor="@color/grad1m"
                        android:textSize="13dp"
                        android:textStyle="normal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />




                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


            <TextView
                android:id="@+id/expense_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:layout_weight="1"
                android:background="@drawable/shape_curve_grey_small"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/avenirnextltpro_medium"
                android:gravity="left"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="Petty Cash Expenses :-"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/textlite"
                android:textSize="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/pettycash_layout" />



            <LinearLayout
                android:id="@+id/expence_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="8dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/expense_title">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/expence_entry"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    app:strokeWidth="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/imageView2"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="16dp"
                            android:src="@drawable/expenses_register"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/textdark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:fontFamily="@font/avenirnextltpro_medium"
                            android:gravity="center_horizontal"
                            android:text="New Expense Entry"

                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/imageView2" />


                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/expence_history"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    app:strokeWidth="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/imageView3"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:padding="16dp"
                            android:src="@drawable/expense_history"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/textdark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:fontFamily="@font/avenirnextltpro_medium"
                            android:gravity="center_horizontal"
                            android:text="Expense Summary"

                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/imageView3" />



                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>


            </LinearLayout>

            <ImageView
                android:id="@+id/tringle1"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="24dp"
                android:scaleType="fitCenter"
                android:visibility="gone"
                android:background="@drawable/shape_tringle"
                android:backgroundTint="@color/lightgrey"
                app:layout_constraintBottom_toTopOf="@+id/expence_detail_container"
                app:layout_constraintStart_toStartOf="@+id/expence_detail_container" />

            <ImageView
                android:id="@+id/tringle2"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="24dp"
                android:scaleType="fitCenter"
                android:visibility="gone"
                android:background="@drawable/shape_tringle"
                android:backgroundTint="@color/lightgrey"
                app:layout_constraintBottom_toTopOf="@+id/expence_detail_container"
                app:layout_constraintEnd_toEndOf="@+id/expence_detail_container" />


            <LinearLayout
                android:id="@+id/expence_detail_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:paddingBottom="16dp"
                android:background="@drawable/shape_curve_grey_big"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/expence_container">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/entry_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/date_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:hint="Enter Date*"
                            android:background="@drawable/shape_curve_grey_small"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            >

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/date_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:clickable="false"
                                android:focusable="false"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="number" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/name_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/shape_curve_grey_small"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"

                            android:hint="Select Party Name*"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/amount_layout">

                            <AutoCompleteTextView
                                android:id="@+id/name_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:layout_weight="1"
                                android:background="#00000000"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="none"
                                android:paddingVertical="6dp"
                                android:singleLine="true"
                                android:textSize="16dp"
                                android:textStyle="normal" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/oth_name_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/shape_curve_grey_small"
                            android:paddingTop="2dp"

                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:hint="Enter party name"
                            android:visibility="gone"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/name_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/oth_name_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="text" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/cateory_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:background="@drawable/shape_curve_grey_small"
                            android:backgroundTint="@color/white"
                            android:hint="Select Expense Type*"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/date_layout">

                            <AutoCompleteTextView
                                android:id="@+id/category_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:layout_weight="1"
                                android:background="#00000000"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="none"
                                android:paddingVertical="6dp"
                                android:singleLine="true"
                                android:textSize="16dp"
                                android:textStyle="normal" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/oth_category_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/shape_curve_grey_small"
                            android:paddingTop="2dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:hint="Enter Expence Type*"
                            android:visibility="gone"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/cateory_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/oth_category_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="text" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/amount_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:hint="Enter amount*"
                            android:background="@drawable/shape_curve_grey_small"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/oth_category_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/amount_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:maxLength="6"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="number" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/vat_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:hint="Enter VAT amount*"
                            android:background="@drawable/shape_curve_grey_small"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/oth_category_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/vat_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="number" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/total_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:hint="Total Amount*"
                            android:background="@drawable/shape_curve_grey_small"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/oth_category_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/total_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:focusable="false"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="number" />

                        </com.google.android.material.textfield.TextInputLayout>

<!--                        <com.google.android.material.textfield.TextInputLayout-->
<!--                            android:id="@+id/expensetype_layout"-->
<!--                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"-->
<!--                            android:layout_width="match_parent"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:layout_marginStart="16dp"-->
<!--                            android:layout_marginTop="16dp"-->
<!--                            android:layout_marginEnd="16dp"-->
<!--                            android:paddingTop="2dp"-->
<!--                            android:background="@drawable/shape_curve_grey_small"-->
<!--                            android:backgroundTint="@color/white"-->
<!--                            android:hint="Select Expense Type"-->
<!--                            app:layout_constraintEnd_toEndOf="parent"-->
<!--                            app:layout_constraintStart_toStartOf="parent"-->
<!--                            app:layout_constraintTop_toBottomOf="@+id/date_layout">-->

<!--                            <AutoCompleteTextView-->
<!--                                android:id="@+id/expensetype_input"-->
<!--                                android:layout_width="match_parent"-->
<!--                                android:layout_height="wrap_content"-->
<!--                                android:layout_marginTop="6dp"-->
<!--                                android:layout_weight="1"-->
<!--                                android:background="#00000000"-->
<!--                                android:fontFamily="@font/avenirnextltpro_medium"-->
<!--                                android:inputType="none"-->
<!--                                android:paddingVertical="6dp"-->
<!--                                android:singleLine="true"-->
<!--                                android:textSize="16dp"-->
<!--                                android:textStyle="normal" />-->

<!--                        </com.google.android.material.textfield.TextInputLayout>-->

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/sdcno_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:hint="Enter SDC No/R"
                            android:background="@drawable/shape_curve_grey_small"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/oth_category_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/sdcno_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:maxLength="12"

                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="textCapCharacters" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/receiptno_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:hint="Enter Receipt No/R"
                            android:background="@drawable/shape_curve_grey_small"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/oth_category_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/receiptno_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="text" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/descrption_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:paddingTop="2dp"
                            android:hint="Description/Remark*"
                            android:background="@drawable/shape_curve_grey_small"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/oth_category_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/descripion_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:maxLines="4"
                                android:backgroundTint="@android:color/transparent"
                                android:fontFamily="@font/avenirnextltpro_medium"
                                android:inputType="textMultiLine" />

                        </com.google.android.material.textfield.TextInputLayout>




                        <LinearLayout
                            android:id="@+id/invoice_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:orientation="vertical"
                            android:background="@drawable/shape_curve_grey_small"
                            android:backgroundTint="@color/white"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"
                            android:layout_gravity="center_horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/oth_name_layout">

                            <ImageView
                                android:id="@+id/invoice_image"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_gravity="center_horizontal"
                                android:src="@drawable/svg_scancam"
                                />


                            <TextView
                                android:id="@+id/invoice_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="Scan Invoice"
                                android:textSize="16dp"
                                android:textColor="@color/textlite"
                                android:fontFamily="@font/avenirnextltpro_medium"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/save_btn"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/avenirnextltpro_medium"
                            android:text="Submit"
                            android:textSize="18dp"
                            android:textColor="@color/textdark"
                            app:cornerRadius="28dp"
                            android:backgroundTint="@color/secondary"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/invoice_layout" />


                    </LinearLayout>




                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/history_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:visibility="gone">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/history_rcv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:layout_marginTop="8dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/progress"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/background_color"
        app:cardCornerRadius="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp"
            android:indeterminate="true"
            android:indeterminateDrawable="@drawable/custom_progress"
            android:indeterminateDuration="800" />

        <!--
                android:indeterminateTint="@color/primery"
        -->

    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>
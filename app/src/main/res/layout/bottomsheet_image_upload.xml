<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="12dp">

    <View
        android:id="@+id/smallview"
        android:layout_width="60dp"
        android:layout_height="5dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/shape_small_view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/close_bottomsheet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/shape_round_round"
        android:backgroundTint="#1443A047"
        android:padding="6dp"
        android:scaleType="centerCrop"
        android:src="@drawable/svg_cross_icon"
        app:layout_constraintBottom_toTopOf="@+id/bsview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--<TextView
        android:id="@+id/bottomsheet_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Register On Templefood"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/smallview" />-->

    <View
        android:id="@+id/bsview"
        android:layout_width="match_parent"
        android:layout_height="0.8dp"
        android:layout_marginTop="32dp"
        android:background="#80707171"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/smallview" />

    <ImageView
        android:id="@+id/gallery_icon"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="8dp"
        android:padding="6dp"
        android:scaleType="centerCrop"
        android:src="@drawable/icon_gallery"
        android:visibility="visible"
        app:layout_constraintEnd_toStartOf="@+id/camera_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bottomsheet_text" />

    <ImageView
        android:id="@+id/camera_icon"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="8dp"
        android:padding="6dp"
        android:scaleType="centerCrop"
        android:src="@drawable/icon_camera"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/gallery_icon"
        app:layout_constraintTop_toBottomOf="@+id/bottomsheet_text" />

    <TextView
        android:id="@+id/bottomsheet_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:gravity="center"
        android:text="Choose an image to upload from"
        android:textSize="16dp"
        android:fontFamily="@font/avenirnextltpro_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bsview" />

    <!--
        <TextView
            android:id="@+id/bottomshee_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Choose An Image To Upload"
            android:textSize="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bottomsheet_text" />
    -->

    <TextView
        android:id="@+id/gallery_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Gallery"
        android:textSize="14dp"
        android:fontFamily="@font/avenirnextltpro_medium"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="@+id/gallery_icon"
        app:layout_constraintStart_toStartOf="@+id/gallery_icon"
        app:layout_constraintTop_toBottomOf="@+id/gallery_icon" />

    <TextView
        android:id="@+id/camera_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Camera"
        android:textSize="14dp"
        android:fontFamily="@font/avenirnextltpro_medium"
        app:layout_constraintEnd_toEndOf="@+id/camera_icon"
        app:layout_constraintStart_toStartOf="@+id/camera_icon"
        app:layout_constraintTop_toBottomOf="@+id/camera_icon" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancel_btn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:text="CANCEL"
        android:textAllCaps="false"
        android:textColor="@color/secondary"
        android:textSize="14dp"
        app:cornerRadius="20dp"
        android:fontFamily="@font/avenirnextltpro_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/bottomsheet_text"
        app:layout_constraintStart_toStartOf="@+id/bottomsheet_text"
        app:layout_constraintTop_toBottomOf="@+id/camera_text"
        app:strokeColor="#C8C4C4"
        app:strokeWidth="1dp" />

    <!--    <ProgressBar
        android:id="@+id/progress_bottomsheet"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:indeterminateDrawable="@drawable/custom_progress_style"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/update_btn" />-->

</androidx.constraintlayout.widget.ConstraintLayout>
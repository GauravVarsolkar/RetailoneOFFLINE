<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- ROW: 3 columns (labels) -->
    <LinearLayout
        android:id="@+id/quantity_layouts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:layout_marginVertical="4dp"
        android:background="@drawable/shape_curve_grey_small"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="3dp"
        android:weightSum="3"
        app:layout_constraintTop_toTopOf="parent">

        <!-- COLUMN 1 -->
        <LinearLayout
            android:id="@+id/batchname_layouts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/batch_names"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Batch"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- COLUMN 2 -->
        <LinearLayout
            android:id="@+id/batch_pricelayouts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/shape_curve_grey_small"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/batch_prices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- COLUMN 3 -->
        <LinearLayout
            android:id="@+id/sale_layouts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/shape_curve_grey_small"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/sale_quantitys"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sold"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Payment card (totals) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/paymentcards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/quantity_layouts">

        <LinearLayout
            android:id="@+id/payments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/colorwhite"
            android:orientation="vertical"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:weightSum="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="Sub Total"
                    android:textColor="#000" />

                <TextView
                    android:id="@+id/subtotalss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RWF0.00"
                    android:textColor="@color/goodgrey"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/taxLayouts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/shape_curve_grey_small"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:weightSum="1">

                <TextView
                    android:id="@+id/taxfields"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="(+) Tax @0%"
                    android:textColor="#000" />

                <TextView
                    android:id="@+id/taxAmountss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RWF0.00"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/discountRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:background="@drawable/shape_curve_grey_small"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:weightSum="1">

                <TextView
                    android:id="@+id/discount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Discount Amount"
                    android:textColor="@color/goodgrey"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/discountamount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RWF 0.00"
                    android:textColor="@color/goodgrey"
                    android:textSize="15sp" />
            </LinearLayout>


            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/shape_dotted_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/shape_curve_grey_small"
                android:backgroundTint="@color/white"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:text="Grand Total"
                    android:textColor="@color/colorgreytwo" />

                <TextView
                    android:id="@+id/alltotalAmountss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RWF0.00"
                    android:textColor="@color/goodgrey" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ROW: Checkbox (left) + Hidden inputs (right) — BELOW payment card -->
    <LinearLayout
        android:id="@+id/row_check_and_inputs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:baselineAligned="false"
        android:gravity="fill_vertical"
        android:orientation="horizontal"
        android:paddingVertical="6dp"
        android:weightSum="3"
        android:background="@drawable/shape_curve_grey_small"
        app:layout_constraintTop_toBottomOf="@id/paymentcards">

        <!-- LEFT: checkbox column -->
        <CheckBox
            android:id="@+id/cb_please_check_it"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:text="Incomplete\nBox"
            android:textSize="12sp" />

        <!-- RIGHT SIDE: inputs (hidden by default) -->
        <LinearLayout
            android:id="@+id/box_bottle_inputs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            android:weightSum="2">

            <!-- No. of Box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_no_of_box_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No. of Box"
                    android:textAlignment="center"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_no_of_box"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/rounded_edittext_background"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:paddingHorizontal="8dp"
                    android:singleLine="true"
                    android:textAlignment="center"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- No. of Bottles -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_number_of_buttols_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No. of Bottles"
                    android:textAlignment="center"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_number_of_buttols"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/rounded_edittext_background"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:inputType="number"
                    android:paddingHorizontal="8dp"
                    android:singleLine="true"
                    android:textAlignment="center"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

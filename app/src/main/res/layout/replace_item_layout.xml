<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cartLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/light_white"
    android:padding="0dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/parent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/white">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp">

                <!-- Checkbox beside product name -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/item_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:useMaterialThemeColors="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@+id/item_name" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/productimg"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/temp"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize" />

                <TextView
                    android:id="@+id/item_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="Product name"
                    android:textColor="@color/colorgreytwo"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/productimg"
                    app:layout_constraintStart_toEndOf="@+id/item_checkbox"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/item_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginStart="8dp"
                    android:text="description"
                    android:textColor="@color/goodgrey"
                    android:textSize="15sp"
                    app:layout_constraintStart_toStartOf="@+id/item_name"
                    app:layout_constraintTop_toBottomOf="@+id/item_name" />

                <LinearLayout
                    android:id="@+id/ll_hold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_hold_round"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@+id/item_desc"
                    app:layout_constraintTop_toBottomOf="@+id/item_desc">

                    <TextView
                        android:id="@+id/tv_hold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOLD"
                        android:textColor="@android:color/white"

                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/item_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="@color/goodgrey"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@+id/item_desc"
                    app:layout_constraintTop_toBottomOf="@+id/item_desc" />

                <TextView
                    android:id="@+id/item_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text=""
                    android:textColor="@color/colorgreytwo"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@+id/item_unit"
                    app:layout_constraintTop_toBottomOf="@+id/item_unit" />

                <TextView
                    android:id="@+id/refund_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text=""
                    android:textColor="@color/colorgreytwo"
                    android:textSize="13sp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="@+id/item_price"
                    app:layout_constraintTop_toBottomOf="@+id/item_price" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- (optional) header row above batches -->
            <LinearLayout
                android:id="@+id/batch_layouts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone"
                android:weightSum="3">

                <TextView
                    android:id="@+id/batch_names"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Batch"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center_horizontal" />

                <TextView
                    android:id="@+id/batch_dispatchs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Price"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center_horizontal" />

                <TextView
                    android:id="@+id/quantitys"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sold"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center_horizontal" />
            </LinearLayout>

            <!-- Child list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/batch_rcv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp" />

            <!-- Keep these so binding.quantEdit compiles -->
            <LinearLayout
                android:id="@+id/quant_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <EditText
                    android:id="@+id/quant_edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_edittext_background"
                    android:gravity="center"
                    android:hint="Quantity"
                    android:inputType="number"
                    android:maxLength="8"
                    android:minWidth="80dp"
                    android:paddingVertical="5dp"
                    android:paddingHorizontal="6dp"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
